<!DOCTYPE html>
<html lang="es">
<head>
    <meta charset="UTF-8">
    <title>CYBER-GRID: PROTOCOLO DE RECOLECCIÓN V3</title>
    <style>
        :root { --accent: #ff6600; --bg: #000000; --ui-bg: rgba(10, 10, 10, 0.9); }
        body { margin: 0; background-color: var(--bg); overflow: hidden; font-family: 'Courier New', monospace; color: var(--accent); }
        
        /* Interfaz de Usuario */
        #ui {
            position: absolute; top: 20px; left: 20px; pointer-events: none;
            background: var(--ui-bg); padding: 20px; border-left: 3px solid var(--accent);
            z-index: 5;
        }
        .stat { font-size: 18px; margin-bottom: 5px; letter-spacing: 2px; }
        .val { color: #fff; }

        /* Pantalla de Inicio / Pausa */
        #overlay {
            position: absolute; width: 100%; height: 100%; background: rgba(0,0,0,0.9);
            display: flex; flex-direction: column; justify-content: center; align-items: center;
            z-index: 10; text-align: center; cursor: pointer;
        }
        #btn-start {
            padding: 20px 40px; border: 2px solid var(--accent); color: var(--accent);
            background: transparent; font-size: 24px; cursor: pointer; font-family: inherit;
            transition: all 0.3s;
        }
        #btn-start:hover { background: var(--accent); color: #000; }

        /* Punto de mira */
        #crosshair {
            position: absolute; top: 50%; left: 50%; width: 15px; height: 15px;
            border: 1px solid var(--accent); transform: translate(-50%, -50%); border-radius: 50%;
            pointer-events: none;
        }
    </style>
</head>
<body>

    <div id="overlay">
        <h1 style="color: #fff; letter-spacing: 5px;">SISTEMA DE EXPLORACIÓN 3D</h1>
        <p style="color: #666; margin-bottom: 30px;">[ SECTOR: VACÍO INDUSTRIAL ]</p>
        <button id="btn-start">INICIAR SECUENCIA</button>
        <p style="font-size: 12px; color: #444; margin-top: 20px;">W A S D para mover | MOUSE para mirar</p>
    </div>

    <div id="ui">
        <div class="stat">NIVEL: <span id="lvl-val" class="val">1</span></div>
        <div class="stat">OBJETIVOS: <span id="core-val" class="val">0 / 5</span></div>
        <div id="msg" style="font-size: 10px; color: #666; margin-top: 10px;">ESTADO: ESCANEANDO ÁREA...</div>
    </div>

    <div id="crosshair"></div>

    <script type="importmap">
        {
            "imports": {
                "three": "https://unpkg.com/three@0.160.0/build/three.module.js",
                "three/addons/": "https://unpkg.com/three@0.160.0/examples/jsm/"
            }
        }
    </script>

    <script type="module">
        import * as THREE from 'three';
        import { PointerLockControls } from 'three/addons/controls/PointerLockControls.js';

        // --- CONFIGURACIÓN TÉCNICA ---
        let level = 1, coresCollected = 0;
        const coresNeeded = 5;
        let cores = [], obstacles = [];
        let scene, camera, renderer, controls;
        let moveForward = false, moveBackward = false, moveLeft = false, moveRight = false;
        
        const velocity = new THREE.Vector3();
        const direction = new THREE.Vector3();
        let prevTime = performance.now();

        init();
        animate();

        function init() {
            // 1. Escena y Niebla Industrial
            scene = new THREE.Scene();
            scene.background = new THREE.Color(0x000000);
            scene.fog = new THREE.Fog(0x000000, 2, 40);

            // 2. Cámara (Altura de ojos humanos)
            camera = new THREE.PerspectiveCamera(75, window.innerWidth / window.innerHeight, 0.1, 1000);
            camera.position.y = 1.7;

            // 3. Renderer
            renderer = new THREE.WebGLRenderer({ antialias: true });
            renderer.setPixelRatio(window.devicePixelRatio);
            renderer.setSize(window.innerWidth, window.innerHeight);
            renderer.shadowMap.enabled = true;
            document.body.appendChild(renderer.domElement);

            // 4. Controles (Pointer Lock)
            controls = new PointerLockControls(camera, document.body);
            const overlay = document.getElementById('overlay');
            const btn = document.getElementById('btn-start');

            btn.addEventListener('click', () => controls.lock());
            controls.addEventListener('lock', () => overlay.style.display = 'none');
            controls.addEventListener('unlock', () => overlay.style.display = 'flex');

            // 5. Luces (Ambiente mínimo + Linterna del jugador)
            const ambient = new THREE.AmbientLight(0xffffff, 0.1);
            scene.add(ambient);
            
            const spotLight = new THREE.SpotLight(0xffffff, 50, 25, Math.PI/6, 0.5);
            spotLight.position.set(0, 0, 1);
            camera.add(spotLight); // La luz sale de la frente del jugador
            camera.add(spotLight.target);
            spotLight.target.position.set(0, 0, -5);
            scene.add(camera);

            generateWorld();

            // Teclado
            document.addEventListener('keydown', (e) => handleKey(e.code, true));
            document.addEventListener('keyup', (e) => handleKey(e.code, false));
            window.addEventListener('resize', onResize);
        }

        function generateWorld() {
            // Limpiar escena anterior
            cores.forEach(c => scene.remove(c));
            obstacles.forEach(o => scene.remove(o));
            cores = []; obstacles = [];

            // Suelo de Rejilla Industrial
            const floorGeo = new THREE.PlaneGeometry(200, 200, 40, 40);
            floorGeo.rotateX(-Math.PI / 2);
            const floorMat = new THREE.MeshPhongMaterial({ 
                color: 0x0a0a0a, 
                wireframe: false, 
                flatShading: true 
            });
            const floor = new THREE.Mesh(floorGeo, floorMat);
            floor.receiveShadow = true;
            scene.add(floor);

            // Crear Objetivos (Cores Naranjas)
            for (let i = 0; i < coresNeeded; i++) {
                const geo = new THREE.IcosahedronGeometry(0.3, 0);
                const mat = new THREE.MeshStandardMaterial({ color: 0xff6600, emissive: 0xff3300, emissiveIntensity: 5 });
                const core = new THREE.Mesh(geo, mat);
                core.position.set((Math.random()-0.5)*50, 0.6, (Math.random()-0.5)*50);
                scene.add(core);
                cores.push(core);
            }

            // Crear Obstáculos (Estructuras de acero)
            for (let i = 0; i < 40; i++) {
                const h = Math.random() * 8 + 2;
                const obsGeo = new THREE.BoxGeometry(1.5, h, 1.5);
                const obsMat = new THREE.MeshPhongMaterial({ color: 0x151515 });
                const obs = new THREE.Mesh(obsGeo, obsMat);
                obs.position.set((Math.random()-0.5)*60, h/2, (Math.random()-0.5)*60);
                scene.add(obs);
                obstacles.push(obs);
            }

            document.getElementById('msg').innerText = "OBJETIVOS LOCALIZADOS. PROCEDA.";
        }

        function handleKey(code, isPressed) {
            switch(code) {
                case 'KeyW': moveForward = isPressed; break;
                case 'KeyS': moveBackward = isPressed; break;
                case 'KeyA': moveLeft = isPressed; break;
                case 'KeyD': moveRight = isPressed; break;
            }
        }

        function animate() {
            requestAnimationFrame(animate);
            const time = performance.now();

            if (controls.isLocked) {
                const delta = (time - prevTime) / 1000;

                // 1. Fricción/Desaceleración (para que no se deslice infinitamente)
                velocity.x -= velocity.x * 10.0 * delta;
                velocity.z -= velocity.z * 10.0 * delta;

                // 2. Dirección del movimiento
                direction.z = Number(moveForward) - Number(moveBackward);
                direction.x = Number(moveRight) - Number(moveLeft);
                direction.normalize();

                // 3. Aplicar Aceleración
                if (moveForward || moveBackward) velocity.z -= direction.z * 400.0 * delta;
                if (moveLeft || moveRight) velocity.x -= direction.x * 400.0 * delta;

                // 4. Aplicar Movimiento a los controles
                controls.moveRight(-velocity.x * delta);
                controls.moveForward(-velocity.z * delta);

                // 5. Lógica de Recolección y Animación
                cores.forEach((core, index) => {
                    core.rotation.y += 0.02;
                    core.position.y = 0.6 + Math.sin(time * 0.003) * 0.1;

                    // Colisión por cercanía
                    if (camera.position.distanceTo(core.position) < 1.5) {
                        scene.remove(core);
                        cores.splice(index, 1);
                        coresCollected++;
                        updateUI();
                        
                        if (coresCollected >= coresNeeded) {
                            nextLevel();
                        }
                    }
                });
            }

            prevTime = time;
            renderer.render(scene, camera);
        }

        function updateUI() {
            document.getElementById('lvl-val').innerText = level;
            document.getElementById('core-val').innerText = `${coresCollected} / ${coresNeeded}`;
        }

        function nextLevel() {
            level++;
            coresCollected = 0;
            // Aumentar dificultad (más niebla)
            scene.fog.far = Math.max(5, 40 - (level * 3));
            generateWorld();
            updateUI();
            document.getElementById('msg').innerText = "NIVEL COMPLETADO. GENERANDO NUEVA GRILLA...";
        }

        function onResize() {
            camera.aspect = window.innerWidth / window.innerHeight;
            camera.updateProjectionMatrix();
            renderer.setSize(window.innerWidth, window.innerHeight);
        }
    </script>
</body>
</html>
